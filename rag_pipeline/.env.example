SUPABASE_URL=https://pyvrgjigxlxzhsitoreo.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Temporary embeddings for semantic boundary detection only.
# Switch providers with EMBEDDING_PROVIDER=openai or EMBEDDING_PROVIDER=gemini.
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=

# Gemini option. To try Gemini Embedding, set:
# EMBEDDING_PROVIDER=gemini
# EMBEDDING_MODEL=gemini-embedding-001
GEMINI_API_KEY=
GEMINI_OUTPUT_DIMENSIONALITY=1536

# Prepared for the next step. The current worker does not write to Qdrant.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=lerncycle_chunks

RAG_CHUNKING_STRATEGY=docling_hybrid_semantic_refinement
RAG_CHUNKING_VERSION=v1
