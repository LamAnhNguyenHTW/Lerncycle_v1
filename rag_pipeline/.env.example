SUPABASE_URL=https://pyvrgjigxlxzhsitoreo.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Embeddings for semantic refinement and durable dense retrieval.
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=100
OPENAI_API_KEY=

# Gemini option. To try Gemini Embedding, set:
# EMBEDDING_PROVIDER=gemini
# EMBEDDING_MODEL=gemini-embedding-001
GEMINI_API_KEY=
GEMINI_OUTPUT_DIMENSIONALITY=1536

# Active dense retrieval index. Supabase remains the source of truth.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=learncycle_chunks

SPARSE_PROVIDER=fastembed
SPARSE_MODEL=Qdrant/bm25
SPARSE_VECTOR_NAME=sparse
SPARSE_ENABLED=true
HYBRID_FUSION=rrf
HYBRID_PREFETCH_LIMIT=30
HYBRID_TOP_K=10
RAG_INTERNAL_API_KEY=dev-secret-change-me

RAG_CHUNKING_STRATEGY=docling_hybrid_semantic_refinement
RAG_CHUNKING_VERSION=v1
