SUPABASE_URL=https://pyvrgjigxlxzhsitoreo.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Embeddings for semantic refinement and durable dense retrieval.
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=100
OPENAI_API_KEY=

# Gemini option. To try Gemini Embedding, set:
# EMBEDDING_PROVIDER=gemini
# EMBEDDING_MODEL=gemini-embedding-001
GEMINI_API_KEY=
GEMINI_OUTPUT_DIMENSIONALITY=1536

# Active dense retrieval index. Supabase remains the source of truth.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=learncycle_chunks

SPARSE_PROVIDER=fastembed
SPARSE_MODEL=Qdrant/bm25
SPARSE_VECTOR_NAME=sparse
SPARSE_ENABLED=true
HYBRID_FUSION=rrf
HYBRID_PREFETCH_LIMIT=30
HYBRID_TOP_K=10
RAG_INTERNAL_API_KEY=dev-secret-change-me

CHAT_MEMORY_ENABLED=false
CHAT_MEMORY_SUMMARY_THRESHOLD=8
CHAT_MEMORY_SUMMARY_INTERVAL=4
CHAT_MEMORY_KEEP_RECENT=4
CHAT_MEMORY_MAX_SUMMARY_CHARS=2500
CHAT_MEMORY_RETRIEVAL_ENABLED=false
CHAT_MEMORY_DEFAULT_INCLUDED=false
CHAT_MEMORY_TOP_K=2
CHAT_MEMORY_SOURCE_TYPE=chat_memory

GRAPH_ENABLED=false
GRAPH_EXTRACTION_ENABLED=false
GRAPH_RETRIEVAL_ENABLED=false
GRAPH_STORE_PROVIDER=neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j
GRAPH_MAX_NODES_PER_CHUNK=12
GRAPH_MAX_EDGES_PER_CHUNK=20
GRAPH_RETRIEVAL_TOP_K=8
GRAPH_CONTEXT_MAX_CHARS=6000
GRAPH_SOURCE_TYPE=knowledge_graph

WEB_SEARCH_ENABLED=false
WEB_SEARCH_PROVIDER=tavily
WEB_SEARCH_TOP_K=5
WEB_SEARCH_TIMEOUT_SECONDS=15
WEB_SEARCH_MAX_QUERY_CHARS=300
WEB_SEARCH_MAX_CONTEXT_SOURCES=5
WEB_SEARCH_MAX_CHARS_PER_SOURCE=1000
WEB_SEARCH_MAX_TOTAL_CONTEXT_CHARS=4000
WEB_SEARCH_SOURCE_TYPE=web
TAVILY_API_KEY=

INTENT_CLASSIFIER_ENABLED=false
INTENT_CLASSIFIER_PROVIDER=openai
INTENT_CLASSIFIER_MODEL=gpt-4.1-mini
INTENT_CLASSIFIER_TIMEOUT_SECONDS=10
INTENT_CLASSIFIER_MAX_RECENT_MESSAGES=4
INTENT_CLASSIFIER_MAX_MESSAGE_CHARS=1000
INTENT_CLASSIFIER_FALLBACK_ENABLED=true

RETRIEVAL_PLANNER_ENABLED=false
RETRIEVAL_PLANNER_DEFAULT_TOP_K=6
RETRIEVAL_PLANNER_PDF_TOP_K=6
RETRIEVAL_PLANNER_NOTES_TOP_K=4
RETRIEVAL_PLANNER_ANNOTATIONS_TOP_K=4
RETRIEVAL_PLANNER_MEMORY_TOP_K=3
RETRIEVAL_PLANNER_WEB_TOP_K=5
RETRIEVAL_PLANNER_MAX_STEPS=5
RETRIEVAL_PLANNER_INCLUDE_DISABLED_STEPS=true

RAG_CHUNKING_STRATEGY=docling_hybrid_semantic_refinement
RAG_CHUNKING_VERSION=v1
